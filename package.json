{
  "name": "toride",
  "version": "1.0.0",
  "description": "Claude Code並列開発を効率化するタスク管理ダッシュボード",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "rebuild": "electron-rebuild -f -w better-sqlite3,node-pty",
    "dist:mac-arm64": "npm run build && electron-builder --mac --arm64",
    "dist:mac-x64": "npm run build && electron-builder --mac --x64",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist": "npm run build && electron-builder --mac --win"
  },
  "build": {
    "appId": "com.take18.toride",
    "productName": "ToRide",
    "copyright": "Copyright © 2024 Take18",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "out/**/*",
      "!out/**/*.map"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ]
    },
    "dmg": {
      "title": "ToRide ${version}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^9.6.0",
    "chokidar": "^3.6.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "simple-git": "^3.27.0",
    "zustand": "^5.0.2"
  }
}
